// Prisma schema — mirrors starter-kit/docs/data-model.md (v4: supplier
// catalog + weekly Excel sync + geo browsing + commission checkout).
// Read that doc (and business-rules.md) before changing any field here.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VerificationStatus {
  pending
  verified
  rejected
}

enum LoginIdentifierType {
  mobile
  email
}

enum CatalogItemStatus {
  active
  inactive
}

enum InventoryUploadStatus {
  processing
  completed
  completed_with_errors
  failed
}

enum SupplyRequestStatus {
  open
  fulfilled
  closed
}

enum SupplyOfferStatus {
  pending
  accepted
  rejected
}

enum TransactionSourceType {
  catalog_purchase
  supply_offer
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum PaymentMethod {
  mada
  card
}

enum PayoutStatus {
  pending
  paid
}

model Pharmacy {
  id                  String              @id @default(cuid())
  // Bridges to Supabase Auth's own user store, same pattern as Supplier.
  authUserId          String              @unique @map("auth_user_id")
  name                String
  licenseNumber       String              @unique @map("license_number")
  licenseDocUrl       String              @map("license_doc_url")
  verificationStatus  VerificationStatus  @default(pending) @map("verification_status")
  loginIdentifierType LoginIdentifierType @map("login_identifier_type")
  mobile              String?             @unique
  email               String?             @unique
  city                String
  district            String?
  address             String
  createdAt           DateTime            @default(now()) @map("created_at")

  supplyRequests SupplyRequest[]
  transactions   Transaction[]

  @@map("pharmacies")
}

model Supplier {
  id                  String              @id @default(cuid())
  authUserId          String              @unique @map("auth_user_id")
  name                String
  sfdaLicenseNumber   String              @unique @map("sfda_license_number")
  sfdaLicenseDocUrl   String              @map("sfda_license_doc_url")
  verificationStatus  VerificationStatus  @default(pending) @map("verification_status")
  loginIdentifierType LoginIdentifierType @map("login_identifier_type")
  mobile              String?             @unique
  email               String?             @unique
  city                String
  district            String?
  createdAt           DateTime            @default(now()) @map("created_at")

  catalogItems     CatalogItem[]
  inventoryUploads InventoryUpload[]
  supplyOffers     SupplyOffer[]
  transactions     Transaction[]

  @@map("suppliers")
}

// A supplier's full catalog — replaces the old standalone Deal model.
// Featured items (is_featured) are a flag on a catalog row, not a
// separate listing type.
model CatalogItem {
  id                 String            @id @default(cuid())
  supplierId         String            @map("supplier_id")
  productName        String            @map("product_name")
  productType        String            @map("product_type")
  sku                String?
  price              Int
  discountPercentage Decimal?          @map("discount_percentage") @db.Decimal(5, 2)
  quantityAvailable  Int               @map("quantity_available")
  isFeatured         Boolean           @default(false) @map("is_featured")
  status             CatalogItemStatus @default(active)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  supplier         Supplier          @relation(fields: [supplierId], references: [id])
  transactionItems TransactionItem[]

  @@index([supplierId, sku])
  @@map("catalog_items")
}

// Log of weekly (or ad hoc) Excel bulk-sync uploads.
model InventoryUpload {
  id           String                @id @default(cuid())
  supplierId   String                @map("supplier_id")
  fileUrl      String                @map("file_url")
  status       InventoryUploadStatus @default(processing)
  rowCount     Int                   @map("row_count")
  successCount Int                   @map("success_count")
  errorCount   Int                   @map("error_count")
  errorDetails Json?                 @map("error_details")
  uploadedAt   DateTime              @default(now()) @map("uploaded_at")

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@map("inventory_uploads")
}

model SupplyRequest {
  id          String              @id @default(cuid())
  pharmacyId  String              @map("pharmacy_id")
  productName String              @map("product_name")
  productType String              @map("product_type")
  quantity    Int
  note        String?
  status      SupplyRequestStatus @default(open)
  createdAt   DateTime            @default(now()) @map("created_at")

  pharmacy Pharmacy      @relation(fields: [pharmacyId], references: [id])
  offers   SupplyOffer[]

  @@map("supply_requests")
}

// When one offer on a request is accepted, all other pending offers on
// the same request are auto-transitioned to rejected in the same
// operation — see business-rules.md "Concurrent supply offers".
model SupplyOffer {
  id              String            @id @default(cuid())
  supplyRequestId String            @map("supply_request_id")
  supplierId      String            @map("supplier_id")
  price           Int
  message         String?
  status          SupplyOfferStatus @default(pending)
  createdAt       DateTime          @default(now()) @map("created_at")
  respondedAt     DateTime?         @map("responded_at")

  supplyRequest    SupplyRequest     @relation(fields: [supplyRequestId], references: [id])
  supplier         Supplier          @relation(fields: [supplierId], references: [id])
  transactionItems TransactionItem[]

  @@map("supply_offers")
}

// Single-row config table for platform-wide settings.
model PlatformSetting {
  id             String   @id @default(cuid())
  commissionRate Decimal  @map("commission_rate") @db.Decimal(5, 4)
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

// One row per checkout, regardless of how many catalog items are in the
// cart. Single-supplier-per-cart is enforced in application logic, not
// by the schema — see data-model.md "Notes for implementation".
model Transaction {
  id                       String                @id @default(cuid())
  sourceType               TransactionSourceType @map("source_type")
  pharmacyId               String                @map("pharmacy_id")
  supplierId               String                @map("supplier_id")
  totalAmount              Int                   @map("total_amount")
  // Copied from PlatformSetting at creation time — must not change
  // retroactively if the global rate changes later.
  commissionRate           Decimal               @map("commission_rate") @db.Decimal(5, 4)
  platformCommissionAmount Int                   @map("platform_commission_amount")
  supplierPayoutAmount     Int                   @map("supplier_payout_amount")
  paymentStatus            PaymentStatus         @default(pending) @map("payment_status")
  paymentMethod            PaymentMethod         @map("payment_method")
  // Set manually/in batch by admin outside the app in v1 — no automated
  // payout scheduling yet.
  payoutStatus             PayoutStatus          @default(pending) @map("payout_status")
  paidAt                   DateTime?             @map("paid_at")
  createdAt                DateTime              @default(now()) @map("created_at")

  pharmacy Pharmacy          @relation(fields: [pharmacyId], references: [id])
  supplier Supplier          @relation(fields: [supplierId], references: [id])
  items    TransactionItem[]

  @@map("transactions")
}

model TransactionItem {
  id            String  @id @default(cuid())
  transactionId String  @map("transaction_id")
  // Null when sourceType = supply_offer.
  catalogItemId String? @map("catalog_item_id")
  // Null when sourceType = catalog_purchase.
  supplyOfferId String? @map("supply_offer_id")
  productName   String  @map("product_name")
  quantity      Int
  unitPrice     Int     @map("unit_price")
  lineTotal     Int     @map("line_total")

  transaction Transaction  @relation(fields: [transactionId], references: [id])
  catalogItem CatalogItem? @relation(fields: [catalogItemId], references: [id])
  supplyOffer SupplyOffer? @relation(fields: [supplyOfferId], references: [id])

  @@map("transaction_items")
}
